// Prisma schema (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  loginId      String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  player       Player?
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Player {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  level     Int      @default(1)
  exp       Int      @default(0)
  hp        Int      @default(100)
  maxHp     Int      @default(100)
  attack    Int      @default(15)
  defense   Int      @default(3)
  gold      Int      @default(0)
  updatedAt DateTime @updatedAt

  // Location and social visibility.
  lastLat       Float?
  lastLng       Float?
  lastSeenAt    DateTime?
  shareLocation Boolean   @default(false)

  // Status and progression.
  healAt        DateTime?
  poisoned      Boolean   @default(false)
  poisonTickAt  DateTime?
  downedUntil   DateTime?
  lastPickupAt  DateTime?
  defeatedSpots String    @default("") // comma-separated spot IDs

  items         PlayerItem[]
  spotStates    PlayerSpotState[]
  listings      MarketListing[] @relation("seller")
  battleLogs    BattleLog[]
  battleSession BattleSession?
}

model ItemMaster {
  itemId      String  @id
  name        String
  description String  @default("")
  rarity      String  @default("normal")
  type        String  @default("misc")
  basePrice   Int     @default(0)
  healAmount  Int     @default(0)
  category    String  @default("misc") // heal/antidote/material/currency/collectible
  curePoison  Boolean @default(false)
  sellable    Boolean @default(true)

  playerItems PlayerItem[]
  listings    MarketListing[]
}

model EnemyMaster {
  enemyId      String @id
  name         String
  hp           Int
  attack       Int
  defense      Int
  image        String @default("")
  expBase      Int    @default(0)
  goldBase     Int    @default(0)
  dropItemId   String?
  dropRate     Float  @default(0)
  poisonChance Float  @default(0)

  spots      SpotMaster[]
  battleLogs BattleLog[]
}

model SpotMaster {
  spotId       String  @id
  name         String
  lat          Float
  lng          Float
  radiusM      Int     @default(50)
  postalCode   String?
  muniCd       String?
  areaName     String?
  areaKey      String?
  enemyId      String
  enemy        EnemyMaster @relation(fields: [enemyId], references: [enemyId])
  rewardItemId String
  penaltyMin   Int     @default(5)
  active       Boolean @default(true)

  spotStates PlayerSpotState[]
}

model PostalAreaMaster {
  areaKey    String @id
  postalCode String?
  muniCd     String
  areaName   String
  regionName String
}

model PlayerItem {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemId   String
  item     ItemMaster @relation(fields: [itemId], references: [itemId])
  qty      Int    @default(1)

  @@unique([playerId, itemId])
}

model PlayerSpotState {
  playerId     String
  player       Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spotId       String
  spot         SpotMaster @relation(fields: [spotId], references: [spotId])
  penaltyUntil DateTime?
  victoryUntil DateTime?

  @@id([playerId, spotId])
}

model MarketListing {
  id        String   @id @default(cuid())
  sellerId  String
  seller    Player   @relation("seller", fields: [sellerId], references: [id])
  itemId    String
  item      ItemMaster @relation(fields: [itemId], references: [itemId])
  qty       Int
  price     Int
  status    String   @default("open") // open / sold / cancelled
  buyerId   String?
  createdAt DateTime @default(now())
  soldAt    DateTime?
}

model BattleLog {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  enemyId   String
  enemy     EnemyMaster @relation(fields: [enemyId], references: [enemyId])
  spotId    String
  result    String
  createdAt DateTime @default(now())
}

model InnMaster {
  innId   String @id
  name    String
  lat     Float
  lng     Float
  radiusM Int    @default(50)
}

model ShopMaster {
  shopId  String @id
  name    String
  lat     Float
  lng     Float
  radiusM Int    @default(50)
}

model BattleSession {
  id            String   @id @default(cuid())
  playerId      String   @unique
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spotId        String
  enemyId       String
  enemyHp       Int
  turn          Int      @default(0)
  poisonApplied Boolean  @default(false)
  status        String   @default("active") // active / won / lost
  createdAt     DateTime @default(now())
}
